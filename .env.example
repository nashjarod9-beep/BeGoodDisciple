# ==========================================
# BEGOODDISCIPLE (BGD) - ENVIRONMENT CONFIG
# ==========================================

# Database - Supabase Postgres Connection
# Use Transaction pooler (port 6543) or Direct connection (port 5432)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-SUPABASE-REF].supabase.co:6543/postgres?pgboiler=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-SUPABASE-REF].supabase.co:5432/postgres"

# Supabase API Credentials
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-SUPABASE-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# DeepSeek AI Integration (Automated Spiritual Summaries / Insights)
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_API_BASE_URL="https://api.deepseek.com"

# Transactional Email Service (Resend / SendGrid / Postmark)
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="your-email-service-api-key"
EMAIL_FROM="BeGoodDisciple <noreply@begooddisciple.com>"

# App URL Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
