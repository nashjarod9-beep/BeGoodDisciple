// BeGoodDisciple (BGD) - Prisma Schema
// Connected to Supabase PostgreSQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Roles in the BGD Platform (A user can be both DISCIPLE and FAISEUR_DE_DISCIPLE)
enum Role {
  DISCIPLE
  FAISEUR_DE_DISCIPLE
  ADMIN
}

// Status for Disciple-Mentor (FD) Relationship
enum StatutRelation {
  ACTIF
  INACTIF
}

// Default Report Frequency
enum FrequenceCompteRendu {
  HEBDOMADAIRE
  MENSUEL
}

// Status for Weekly / Monthly Reports
enum ReportStatus {
  DRAFT
  SENT
  REVIEWED
}

// 12 Annual Objective Category Types
enum CategorieType {
  PRIERE_PERSONNELLE
  PRIERE_DE_GROUPE
  LECTURE_BIBLIQUE
  MEDITATION
  EVANGELISATION
  LITTERATURE_CHRETIENNE
  RETRAITES_SPIRITUELLES
  DONS_OFFRANDES
  VISITES_PASTORALES
  ENSEIGNEMENTS
  CARACTERE
  CUSTOM
}

// User Model (Maps to Supabase Auth & platform preferences)
model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  firstName           String?
  lastName            String?
  roles               Role[]               @default([DISCIPLE])
  avatarUrl           String?
  timezone            String               @default("Europe/Paris")
  defaultFrequency    FrequenceCompteRendu @default(HEBDOMADAIRE)
  onboardingCompleted Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Relationships as Disciple & as Faiseur de Disciple (FD)
  discipleRelations   RelationDiscipolat[] @relation("DiscipleRelations")
  mentorRelations     RelationDiscipolat[] @relation("MentorRelations")

  // Annual Objectives & Reports
  objectifsAnnuels    ObjectifAnnuel[]
  sentReports         Report[]             @relation("DiscipleReports")
  receivedReports     Report[]             @relation("MentorReports")
}

// History of Disciple <-> Mentor (FD) Relationships
model RelationDiscipolat {
  id                     String         @id @default(uuid())
  discipleId             String
  disciple               User           @relation("DiscipleRelations", fields: [discipleId], references: [id], onDelete: Cascade)
  
  faiseurDeDiscipleEmail String
  faiseurDeDiscipleId    String?
  faiseurDeDisciple      User?          @relation("MentorRelations", fields: [faiseurDeDiscipleId], references: [id], onDelete: SetNull)
  
  statut                 StatutRelation @default(ACTIF)
  dateDebut              DateTime       @default(now())
  dateFin                DateTime?
  
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
}

// Annual Objectives container with Versioning
model ObjectifAnnuel {
  id          String             @id @default(uuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  annee       Int                @default(2026)
  version     Int                @default(1)
  isCurrent   Boolean            @default(true)
  categories  ObjectifCategorie[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

// Specific Category Goal Configuration (Stored as flexible JSON payload)
model ObjectifCategorie {
  id               String         @id @default(uuid())
  objectifAnnuelId String
  objectifAnnuel   ObjectifAnnuel @relation(fields: [objectifAnnuelId], references: [id], onDelete: Cascade)
  type             CategorieType
  config           Json           // Flexible JSON storing target values, frequencies, custom questions & types
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Report {
  id           String       @id @default(uuid())
  discipleId   String
  disciple     User         @relation("DiscipleReports", fields: [discipleId], references: [id], onDelete: Cascade)
  mentorId     String?
  mentor       User?        @relation("MentorReports", fields: [mentorId], references: [id], onDelete: SetNull)
  status       ReportStatus @default(DRAFT)
  summary      String?
  sentAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
